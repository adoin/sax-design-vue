{
  "private": true,
  "workspaces": [
    "packages/*",
    "play",
    "docs"
  ],
  "scripts": {
    "cz": "czg",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ssr": "vitest --config ./ssr-testing/vitest.config.ts",
    "prepare:e2e": "if [ ! -d \"docs/.vuepress/dist\" ]; then pnpm run docs:build; fi;",
    "dev": "pnpm run docs:dev",
    "play:dev": "pnpm -C play dev",
    "gen": "bash ./scripts/gc.sh",
    "gen:version": "tsx scripts/gen-version.ts",
    "diff:table": "tsx scripts/build-table.ts",
    "gap:analysis": "tsx scripts/gap-analysis.ts",
    "gen:component-docs": "tsx scripts/generate-new-component-docs.ts",
    "gen:icons": "node scripts/generate-extra-icons.mjs",
    "update:version": "tsx scripts/update-version.ts",
    "clean": "pnpm run clean:dist && pnpm run -r --parallel clean",
    "clean:dist": "rimraf dist",
    "build": "pnpm run -C internal/build start",
    "build:theme": "pnpm run -C packages/theme-chalk build",
    "format": "prettier --write --cache .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache",
    "lint:fix": "pnpm run lint --fix",
    "lint:commit": "commitlint --from $(git merge-base origin/main HEAD) --to HEAD > ./commit-lint.txt",
    "typecheck": "run-p typecheck:web typecheck:play typecheck:node typecheck:vite-config typecheck:vitest",
    "typecheck:web": "vue-tsc -p tsconfig.web.json --composite false --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:play": "vue-tsc -p tsconfig.play.json --composite false --noEmit",
    "typecheck:vite-config": "vue-tsc -p tsconfig.vite-config.json --composite false --noEmit",
    "typecheck:vitest": "vue-tsc -p tsconfig.vitest.json --composite false --noEmit",
    "docs:dev": "pnpm run -C docs dev",
    "docs:build": "pnpm run -C docs build",
    "stub": "pnpm run -r --parallel stub",
    "prepare": "husky install",
    "postinstall": "pnpm stub && concurrently \"pnpm gen:version\" \"pnpm run -C internal/metadata dev\""
  },
  "peerDependencies": {
    "vue": "^3.3.4"
  },
  "dependencies": {
    "@tanstack/vue-virtual": "^3.13.33",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@vuesax-alpha/components": "workspace:*",
    "@vuesax-alpha/constants": "workspace:*",
    "@vuesax-alpha/directives": "workspace:*",
    "@vuesax-alpha/hooks": "workspace:*",
    "@vuesax-alpha/icons-vue": "0.0.2-beta.12",
    "@vuesax-alpha/locale": "workspace:*",
    "@vuesax-alpha/test-utils": "workspace:*",
    "@vuesax-alpha/theme-chalk": "workspace:*",
    "@vuesax-alpha/tokens": "workspace:*",
    "@vuesax-alpha/utils": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "@vueuse/shared": "^14.3.0",
    "async-validator": "^4.2.5",
    "dayjs": "^1.11.21",
    "escape-html": "^1.0.3",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "lodash-unified": "^1.0.3",
    "memoize-one": "^6.0.0",
    "normalize-wheel-es": "^1.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@esbuild-kit/cjs-loader": "^2.4.4",
    "@pnpm/find-workspace-packages": "^6.0.9",
    "@pnpm/logger": "^1100.0.0",
    "@pnpm/types": "^1101.4.0",
    "@types/fs-extra": "^11.0.4",
    "@types/gulp": "^4.0.18",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/sass": "^1.45.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vuesax-alpha/build": "workspace:^",
    "@vuesax-alpha/build-utils": "workspace:^",
    "@vuesax-alpha/eslint-config": "workspace:*",
    "@vuesax-alpha/icons-vue": "0.0.2-beta.11",
    "c8": "^12.0.0",
    "chalk": "^5.6.2",
    "concurrently": "^10.0.3",
    "consola": "^3.4.2",
    "csstype": "^3.2.3",
    "cz-git": "^1.13.1",
    "czg": "^1.13.1",
    "eslint": "^8.57.0",
    "eslint-define-config": "^2.1.0",
    "expect-type": "^1.4.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "puppeteer": "^25.3.0",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^6.1.3",
    "sass": "^1.101.3",
    "ts-morph": "^27.0.2",
    "tsx": "^4.23.1",
    "type-fest": "^5.8.0",
    "typescript": "^5.9.3",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-macros": "^2.14.5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">= 18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx,md,json}": "eslint --fix"
  }
}
