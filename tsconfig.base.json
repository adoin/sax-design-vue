{
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2018",
    "module": "esnext",
    "baseUrl": ".",
    "sourceMap": false,
    "moduleResolution": "node",
    "allowJs": false,
    "strict": true,
    "noUnusedLocals": true,
    "noUncheckedSideEffectImports": false,
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "removeComments": false,
    "rootDir": ".",
    "types": [],
    "paths": {
      "@sax-design-vue/icons-vue": ["packages/icons-vue/src/index"],
      "@vuesax-alpha/icons-vue": [
        "node_modules/@vuesax-alpha/icons-vue/dist/types/index"
      ],
      "@vuesax-alpha/*": ["packages/*"]
    }
  }
}
